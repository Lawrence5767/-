# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Claude model to use (default: claude-sonnet-4-5)
# Options: claude-opus-4-6, claude-sonnet-4-5, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-5

# Optional: Prefix to trigger the bot (default: !ai)
# Only messages starting with this prefix will be processed
BOT_PREFIX=!ai

# Optional: Maximum tokens in Claude's response (default: 1024)
MAX_TOKENS=1024

# Optional: Number of messages to keep in conversation history (default: 20)
MAX_HISTORY=20

# Optional: Custom system prompt for Claude
# SYSTEM_PROMPT=You are a helpful AI assistant on WhatsApp.
