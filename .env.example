# TikTok Ads API Credentials
# Copy this file to .env and fill in your values
#
# HOW TO GET THESE VALUES:
# 1. Go to https://business-api.tiktok.com/portal
# 2. Create an app → you'll get APP_ID and APP_SECRET
# 3. Your ADVERTISER_ID is in TikTok Ads Manager dashboard
# 4. Run: python tiktok_ads/auth_helper.py  to get your ACCESS_TOKEN
#
# Set to "sandbox" for testing or "production" for live ads
TIKTOK_ENV=sandbox

TIKTOK_APP_ID=your_app_id_here
TIKTOK_APP_SECRET=your_app_secret_here
TIKTOK_ACCESS_TOKEN=your_access_token_here
TIKTOK_ADVERTISER_ID=your_advertiser_id_here
