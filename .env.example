# Anthropic API Key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Facebook App Credentials
# Get these from https://developers.facebook.com/apps/
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Facebook Page Access Token (long-lived)
# Generate from Graph API Explorer or your app settings
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token

# Webhook Verify Token (you define this - must match Facebook App webhook config)
FACEBOOK_VERIFY_TOKEN=your-custom-verify-token

# Optional: Facebook Page ID (auto-detected from token if not set)
FACEBOOK_PAGE_ID=

# Server Configuration
PORT=5000
