# =============================================================================
# TikTok Ads Analyzer — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Anthropic (Claude) API Key
# -----------------------------------------------------------------------------
# Get your key at: https://console.anthropic.com/settings/keys
#
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# 2. TikTok Marketing API Credentials
# -----------------------------------------------------------------------------
# Follow these steps to get your TikTok API access:
#
# Step 1: Create a TikTok for Business developer account
#   → Go to https://business-api.tiktok.com/portal/docs
#   → Click "Create an app" and register
#
# Step 2: Create an app
#   → In the developer portal, create a new app
#   → Select "Marketing API" as the product
#   → Request these permissions:
#       - Ad Account Management (read)
#       - Campaign Management (read)
#       - Ad Management (read)
#       - Reporting (read)
#       - Audience Management (read)
#
# Step 3: Get approved
#   → Submit your app for review
#   → TikTok typically approves within 1-2 business days
#
# Step 4: Generate an access token
#   → After approval, go to your app settings
#   → Use the authorization flow or generate a long-lived access token
#   → The token gives access to specific advertiser accounts
#
# Step 5: Find your Advertiser ID
#   → Log in to TikTok Ads Manager (https://ads.tiktok.com)
#   → Your Advertiser ID is in the URL or under Account Settings
#   → Format: a numeric string like "7123456789012345678"
#
TIKTOK_ACCESS_TOKEN=your_access_token_here
TIKTOK_ADVERTISER_ID=your_advertiser_id_here
